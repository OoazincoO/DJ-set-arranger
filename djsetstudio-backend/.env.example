# Flask环境配置
FLASK_ENV=development
# 可选值: development, production

# 密钥配置（生产环境请使用强密码）
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# 数据库配置
# 开发环境使用SQLite
DATABASE_URL=sqlite:///djsetstudio.db

# 生产环境使用PostgreSQL（示例）
# DATABASE_URL=postgresql://username:password@localhost:5432/djsetstudio

# CORS配置（允许的跨域来源）
CORS_ORIGINS=*
# 生产环境建议指定具体域名，例如: https://your-domain.com

# 服务器配置
HOST=0.0.0.0
PORT=5000
